# =====================================================================
# GoldenAge AI — Environment Variables
# =====================================================================
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#
# All Flutter secrets are read at compile time via --dart-define
# (see lib/core/constants.dart). The mapping is documented below.
# =====================================================================

# --- Supabase -----------------------------------------------------------
# Get these from https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Map ---------------------------------------------------------------
# AutoNavi / 高德 Web API key
# https://lbs.amap.com/dev/key/app
AMAP_API_KEY=

# --- AI ----------------------------------------------------------------
# OpenAI — used for chat completions + text-embedding-3-small
OPENAI_API_KEY=
# Optional: swap to Anthropic by setting both OPENAI_API_KEY and OPENAI_PROVIDER
OPENAI_PROVIDER=openai   # 'openai' | 'anthropic'
ANTHROPIC_API_KEY=

# --- Edge Functions (server-side secrets) ------------------------------
# Twilio (SMS to guardians on SOS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=      # e.g. +15555550100

# Firebase Cloud Messaging (push notifications)
FCM_SERVER_KEY=

# --- Supabase Management API (used by bin/setup_supabase.sh) ----------
# Personal access token from https://supabase.com/dashboard/account/tokens
SUPABASE_MANAGEMENT_TOKEN=
# The Supabase org you want the new project under
SUPABASE_ORG_ID=
# Region — closest to your users. e.g. ap-southeast-1, us-east-1
SUPABASE_REGION=ap-southeast-1
# Desired database password (8+ chars, no quotes)
SUPABASE_DB_PASSWORD=
