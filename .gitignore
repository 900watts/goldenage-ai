# --- Flutter / Dart --------------------------------------------------
.dart_tool/
.packages
.pub-cache/
.pub/
build/
.flutter-plugins
.flutter-plugins-dependencies
pubspec.lock
.flutter/

# Platform folders (generated by `flutter create .`)
# Uncomment the platforms you DO want to track.
# android/
# ios/
# windows/
# macos/
# linux/
# web/

# --- Secrets & local config -----------------------------------------
.env
.env.local
# bin/*.mjs scripts read SUPABASE_MGMT_TOKEN from env; never hardcode tokens here
bin/*.mjs
**/google-services.json
**/GoogleService-Info.plist
**/key.properties
android/app/google-services.json
android/key.properties

# --- Editor / OS -----------------------------------------------------
.vscode/
.idea/
*.iml
.DS_Store
Thumbs.db
*.swp
*.swo

# --- Logs ------------------------------------------------------------
*.log
logs/

# --- Research clones (not project code) -----------------------------
hermes-agent/
openclaw/

# --- WorkBuddy project internals ------------------------------------
.workbuddy/memory/*.md
!/.workbuddy/memory/.gitkeep

.vercel

# --- Local WorkBuddy helper scripts (embed tokens, NEVER commit) ----
_*.py
_secrets.py
_claim*.txt
_done*.txt
claim_*.txt
done_*.txt
TRAE_PROMPT.md
